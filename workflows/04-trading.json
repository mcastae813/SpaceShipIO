        460,
        300
      ],
      "id": "264a94d7-ebdb-404f-a1db-349bb5a414ca"
    },
    {
      "name": "Find Top Margins",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "parameters": {
        "jsCode": "\nconst market = $input.first().json.data;\nif (!market?.tradeGoods?.length) return [{json:{skip:true, reason:'no trade goods'}}];\nconst goods = market.tradeGoods\n  .map(g => ({symbol: g.symbol, margin: g.sellPrice - g.purchasePrice, buy: g.purchasePrice, sell: g.sellPrice}))\n  .filter(g => g.margin > 50)\n  .sort((a,b) => b.margin - a.margin)\n  .slice(0,5);\nif (!goods.length) return [{json:{skip:true, reason:'no margins > 50'}}];\nconst lines = goods.map(g => `${g.symbol}: ${g.buy}\u2192${g.sell} (+${g.margin})`).join('\\n');\nreturn [{json:{skip:false, message:`\ud83d\udcc8 X1-UX96-A1 top margins:\\n${lines}`}}];\n"
      },
      "position": [
        680,
        300
      ],
      "id": "ca08fc18-44f2-4feb-8a89-67202c88450f"
    },
    {
      "name": "Has Margins?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "a1",
              "leftValue": "={{ $json.skip }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "false"
              }
            }
          ]
        }
      },
      "position": [
        900,
        300
      ],
      "id": "21e1f2a2-e640-49d1-b259-b77c532c7d97"
    },
    {
      "name": "Send Hint",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "parameters": {
        "method": "POST",
        "url": "http://localhost:5678/webhook/spaceship-notify",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"title\":\"\ud83d\udcb9 Trading Engine\",\"message\":\"{{ $json.message }}\",\"severity\":\"info\"}",
        "options": {}
      },
      "position": [
        1120,
        220
      ],
      "id": "9afc7d8c-455c-4d5b-9b79-e579c38a079a"
    },
