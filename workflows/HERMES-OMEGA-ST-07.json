      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst ships = $input.first().json?.data;\n// FIX #1: Only overwrite ships if API returned valid data (not empty/failed)\nif (Array.isArray(ships) && ships.length > 0) {\n  staticData.ships = ships;\n  console.log('PREPARE: stored ' + ships.length + ' ships');\n} else {\n  console.log('PREPARE: no ships data, keeping cached count=' + (staticData.ships||[]).length);\n}\nif (!Array.isArray(ships) || ships.length === 0) { \n  return [{ json: { warning: 'no_ships', cached: (staticData.ships||[]).length } }]; \n}\nreturn [{ json: { system: ships[0].nav.systemSymbol, shipCount: ships.length } }];"
      },
      "id": "ece2c8fb-e7c2-4ac2-8a79-a98d0386b80f"
    },
