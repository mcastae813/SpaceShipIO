    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst MINE_WP  = 'X1-HC40-B8';\nconst FUEL_WP  = 'X1-HC40-B6';\nconst MIN_FUEL = 280;\n\n// Get contracts from single input (Get Contracts)\nconst contracts = $input.first().json?.data || [];\nconst arr = Array.isArray(contracts) ? contracts : [contracts];\nconst activeC = arr.find(c => c.accepted && !c.fulfilled) || null;\nconst tradeSym = activeC?.terms?.deliver?.[0]?.tradeSymbol;\nconst deliverDest = activeC?.terms?.deliver?.[0]?.destinationSymbol;\nif (!deliverDest) { return [{json:{action:'idle',reason:'no_dest'} }]; }\n\n// FIX #4: Debug logging\nconst _shipCount = (staticData.ships||[]).length;\nconst _surveyAge = staticData.survey ? Math.round((Date.now() - new Date(staticData.survey.expiration).getTime())/1000) : 'none';\nconsole.log('MC: ships=' + _shipCount + ' trade=' + tradeSym + ' deliver=' + deliverDest + ' surveyAge=' + _surveyAge);\n\nfunction getRole(s) { const f=s.frame?.symbol||''; if(f.includes('PROBE')||f.includes('SATELLITE'))return null; if(f.includes('FRIGATE'))return 'hauler'; if((s.mounts||[]).some(m=>m.symbol?.includes('MINING_LASER')))return 'miner'; return null; }\nconst ships=staticData.ships||[]; const actions=[];\nfor(const ship of ships){\n  if(!getRole(ship))continue;\n  const nav=ship.nav, status=nav.status, wp=nav.waypointSymbol, fuel=ship.fuel, cargo=ship.cargo;\n  const cargoPct=cargo.capacity>0?cargo.units/cargo.capacity:0, sym=ship.symbol, fm=nav.flightMode||'CRUISE';\n  if(status==='IN_TRANSIT'){if(fm==='DRIFT'){actions.push({action:'set_cruise',ship:sym});}continue;}\n  if(new Date(ship.cooldown?.expiration||0).getTime()>Date.now())continue;\n  const tu=(cargo.inventory||[]).filter(i=>i.symbol===tradeSym).reduce((s,i)=>s+i.units,0);\n  const junk=(cargo.inventory||[]).filter(i=>i.symbol!==tradeSym&&i.units>0);\n  \n  // At deliver destination with trade ore -> dock and deliver\n  if(wp===deliverDest&&tu>0){if(status==='DOCKED'){actions.push({action:'deliver',ship:sym,tradeSymbol:tradeSym,units:tu,contractId:activeC?.id});continue;}if(status==='IN_ORBIT'){actions.push({action:'dock',ship:sym});continue;}}\n  // At deliver destination without trade ore -> return to mine\n  if(wp===deliverDest&&tu===0){if(status==='DOCKED'){actions.push({action:'orbit',ship:sym});continue;}if(status==='IN_ORBIT'){if(fm!=='CRUISE'){actions.push({action:'set_cruise',ship:sym});continue;}actions.push({action:'navigate',ship:sym,waypoint:MINE_WP,reason:'return_to_mine',flightMode:'CRUISE'});continue;}}\n  // Fuel stop\n  if(wp===FUEL_WP&&fuel.current<fuel.capacity-5){if(status==='DOCKED'){actions.push({action:'refuel',ship:sym});continue;}if(status==='IN_ORBIT'){actions.push({action:'dock',ship:sym});continue;}}\n  \n  // Have trade ore somewhere -> navigate to deliver\n  if(tu>0&&wp!==deliverDest){if(fuel.current<MIN_FUEL&&status==='IN_ORBIT'&&wp!==FUEL_WP){if(fm!=='DRIFT'){actions.push({action:'set_drift',ship:sym});continue;}}if(status==='IN_ORBIT'){if(fm!=='CRUISE'){actions.push({action:'set_cruise',ship:sym});continue;}actions.push({action:'navigate',ship:sym,waypoint:deliverDest,reason:'deliver',flightMode:'CRUISE'});continue;}if(status==='DOCKED'){actions.push({action:'orbit',ship:sym});continue;}}\n  \n  // FIX #2: Jettison junk at 10% (was 30%)\n  if(junk.length>0&&cargoPct>=0.10){console.log('JETTISON: '+sym+' junk='+junk.length+' types pct='+cargoPct.toFixed(2));for(const j of junk)actions.push({action:'jettison',ship:sym,symbol:j.symbol,units:j.units});continue;}\n  \n  // FIX: At mine WP with low fuel -> divert to fuel station\n  if(wp===MINE_WP&&fuel.current<MIN_FUEL&&status==='IN_ORBIT'){if(fm!=='DRIFT'){actions.push({action:'set_drift',ship:sym});continue;}actions.push({action:'navigate',ship:sym,waypoint:FUEL_WP,reason:'low_fuel_at_mine',flightMode:'DRIFT'});continue;}\n  // FIX: At mine WP with junk cargo -> jettison before mining\n  if(wp===MINE_WP&&junk.length>0&&cargoPct>=0.10){for(const j of junk)actions.push({action:'jettison',ship:sym,symbol:j.symbol,units:j.units});continue;}\n\n  // Navigate to mine\n  if(wp!==MINE_WP){if(fuel.current<MIN_FUEL&&status==='IN_ORBIT'&&wp!==FUEL_WP){if(fm!=='DRIFT'){actions.push({action:'set_drift',ship:sym});continue;}}if(status==='IN_ORBIT'){if(fm!=='CRUISE'){actions.push({action:'set_cruise',ship:sym});continue;}actions.push({action:'navigate',ship:sym,waypoint:MINE_WP,reason:'mine',flightMode:'CRUISE'});continue;}if(status==='DOCKED'){actions.push({action:'orbit',ship:sym});continue;}}\n  \n  // FIX #3: At mine -> always survey first, never mine without valid survey\n  if(wp===MINE_WP){if(status==='DOCKED'){actions.push({action:'orbit',ship:sym});continue;}if(status==='IN_ORBIT'){const sv=staticData.survey;const v=sv&&new Date(sv.expiration).getTime()>Date.now();if(!v){console.log('SURVEY: '+sym+' creating new survey');actions.push({action:'survey',ship:sym});continue;}actions.push({action:'mine_survey',ship:sym,survey:sv});console.log('MINE_SURVEY: '+sym+' using survey expires='+sv.expiration);continue;}}\n}\nconsole.log('MC: actions='+actions.length);\nreturn actions.length>0?actions.map(a=>({json:a})):[{json:{action:'idle',reason:'no_actions'}}];"
      },
