    {
      "name": "Parse Waypoints",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        660,
        400
      ],
      "parameters": {
        "jsCode": "// Parse Waypoints — find and cache key waypoints in staticData\nconst wpData = $input.first().json;\nconst waypoints = wpData.data || [];\nlet MINE_WP = null;\nlet SELL_WP = null;\nlet FUEL_WP = null;\nfor (const wp of waypoints) {\n  const type = wp.type || '';\n  if (type === 'ENGINEERED_ASTEROID' && !MINE_WP) { MINE_WP = wp.symbol; }\n  if (type === 'ASTEROID_BASE' && !SELL_WP) { SELL_WP = wp.symbol; }\n  if (type === 'FUEL_STATION' && !FUEL_WP) { FUEL_WP = wp.symbol; }\n}\n// Fallback: use first asteroid if no engineered one found\nif (!MINE_WP) {\n  const firstAsteroid = waypoints.find(w => w.type === 'ASTEROID');\n  if (firstAsteroid) MINE_WP = firstAsteroid.symbol;\n}\nconst sd = $getWorkflowStaticData('global');\nsd.wp = { MINE: MINE_WP, SELL: SELL_WP, FUEL: FUEL_WP, ts: Date.now() };\nreturn [{ json: { MINE_WP, SELL_WP, FUEL_WP, wpCount: waypoints.length } }];"
      },
      "id": "e547974f-abfb-412b-a67f-8cb7a763af01"
    },
    {
