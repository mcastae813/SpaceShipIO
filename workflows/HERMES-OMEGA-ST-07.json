    {
      "name": "Store Survey",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst result = $input.first().json;\nconst surveys = result.data?.surveys || [];\n// Pick survey with most ore deposits (any type)\nlet best = null;\nlet bestScore = -1;\nfor (const s of surveys) {\n  const score = (s.deposits || []).filter(d => \n    !d.symbol.includes('CRYSTALS') && !d.symbol.includes('SAND') && !d.symbol.includes('ICE')\n  ).length;\n  if (score > bestScore) { bestScore = score; best = s; }\n}\nif (!best && surveys.length > 0) best = surveys[0];\nif (best) { staticData.survey = best; return [{json:{stored:true, deposits: best.deposits?.map(d=>d.symbol)}}]; }\nreturn [{json:{stored:false}}];"
      },
      "position": [
        1680,
        840
      ],
      "id": "0b91d500-7b7f-4fb0-98ac-6d0865a8d2dc"
    },
