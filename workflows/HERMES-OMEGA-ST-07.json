    {
      "id": "deliver-guard-1",
      "name": "Deliver Guard",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        300
      ],
      "parameters": {
        "jsCode": "\nconst staticData = $getWorkflowStaticData('global');\nconst input = $input.first().json;\n\n// Track failed deliveries: {shipSymbol: lastFailTimestamp}\nif (!staticData.deliverFails) staticData.deliverFails = {};\n\nconst ship = input.ship;\nconst now = Date.now();\n\n// Check if this ship recently failed to deliver (cooldown: 5 minutes)\nconst lastFail = staticData.deliverFails[ship];\nif (lastFail && (now - lastFail) < 5 * 60 * 1000) {\n  // Still in fail cooldown - skip delivery\n  return [{json: {action: 'deliver_skipped', ship, reason: 'fail_cooldown', retryIn: Math.ceil((5*60*1000 - (now - lastFail))/1000) + 's'}}];\n}\n\n// Validate params\nif (!input.contractId || !input.tradeSymbol || !input.units || input.units <= 0) {\n  staticData.deliverFails[ship] = now;\n  return [{json: {action: 'deliver_skipped', ship, reason: 'invalid_params', contractId: input.contractId, tradeSymbol: input.tradeSymbol, units: input.units}}];\n}\n\n// Params look good - allow delivery\nreturn [$input.first()];\n"
      }
    },
